---
import BaseLayout from "../layouts/BaseLayout.astro"
import Gallery from "../components/Gallery.astro"

const portraits = [
  { src: "/images/gallery-01.jpg", alt: "A grumpy-looking Pallas's cat in snow", caption: "Winter coat, full frost." },
  { src: "/images/gallery-03.jpg", alt: "Macro of a Pallas's cat's eyes", caption: "Round pupils and amber eyes." },
  { src: "/images/gallery-08.jpg", alt: "A Pallas's cat yawning", caption: "A wide yawn on the steppe." },
  { src: "/images/overview-hero.jpg", alt: "Portrait of a Pallas's cat's flat face", caption: "The unmistakable flattened face." },
  { src: "/images/gallery-04.jpg", alt: "A Pallas's cat peeking over a rock", caption: "Peering over cover." },
  { src: "/images/texture-fur.jpg", alt: "Macro texture of Pallas's cat fur", caption: "The densest coat of any cat." },
]

const habitatShots = [
  { src: "/images/gallery-11.jpg", alt: "A Pallas's cat on a ridge above a valley", caption: "Surveying the valley below." },
  { src: "/images/gallery-02.jpg", alt: "A Pallas's cat walking across the steppe", caption: "Low and stocky in profile." },
  { src: "/images/gallery-12.jpg", alt: "A Pallas's cat in autumn grasses", caption: "Autumn on the steppe." },
  { src: "/images/gallery-10.jpg", alt: "A Pallas's cat hidden in tall grass", caption: "Camouflaged in dry grass." },
  { src: "/images/habitat-hero.jpg", alt: "Steppe and rocky highland landscape", caption: "Classic manul country." },
  { src: "/images/conservation-hero.jpg", alt: "A lone Pallas's cat at golden hour", caption: "Solitude at sunset." },
]

const lifeShots = [
  { src: "/images/repro-hero.jpg", alt: "Two Pallas's cat kittens at a den", caption: "Kittens at the den entrance." },
  { src: "/images/gallery-09.jpg", alt: "A single Pallas's cat kitten", caption: "A young manul exploring." },
  { src: "/images/gallery-05.jpg", alt: "A Pallas's cat curled up resting", caption: "Resting, tail wrapped close." },
  { src: "/images/gallery-06.jpg", alt: "A Pallas's cat in deep snow", caption: "Built for brutal winters." },
  { src: "/images/gallery-07.jpg", alt: "A Pallas's cat stretching up a rock", caption: "Reaching into a crevice." },
  { src: "/images/diet-hero.jpg", alt: "A Pallas's cat stalking at dusk", caption: "The patient ambush." },
]
---

<BaseLayout
  title="Gallery — The Manul Atlas"
  description="An extensive photographic gallery of the Pallas's cat: portraits, habitat, and life on the steppe."
  image="/images/gallery-01.jpg"
>
  <header class="border-b border-line bg-ink text-parchment">
    <div class="mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-28">
      <p class="eyebrow text-gold">The collection</p>
      <h1 class="mt-4 max-w-3xl text-balance font-serif text-4xl font-semibold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
        A photographic study of the manul
      </h1>
      <p class="mt-6 max-w-2xl text-pretty text-lg leading-relaxed text-parchment/80">
        Eighteen frames across portrait, habitat, and life history. Select any image to view it full size.
      </p>
    </div>
  </header>

  <section class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <h2 class="mb-2 font-serif text-3xl font-semibold tracking-tight text-ink">Portraits & detail</h2>
    <p class="mb-8 max-w-2xl text-ink-soft">The face, the eyes, and the extraordinary coat that define the species.</p>
    <Gallery images={portraits} columns={3} />
  </section>

  <section class="border-y border-line bg-parchment-2">
    <div class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
      <h2 class="mb-2 font-serif text-3xl font-semibold tracking-tight text-ink">Habitat & landscape</h2>
      <p class="mb-8 max-w-2xl text-ink-soft">The open steppe, rocky ridges, and high country the manul calls home.</p>
      <Gallery images={habitatShots} columns={3} />
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <h2 class="mb-2 font-serif text-3xl font-semibold tracking-tight text-ink">Life & behavior</h2>
    <p class="mb-8 max-w-2xl text-ink-soft">Kittens, rest, winter survival, and the hunt.</p>
    <Gallery images={lifeShots} columns={3} />
  </section>
</BaseLayout>
