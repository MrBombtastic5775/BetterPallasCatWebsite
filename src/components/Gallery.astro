---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro:assets'

interface ImageItem {
  src: ImageMetadata
  alt: string
  caption?: string
}

interface Props {
  images: ImageItem[]
  columns?: 2 | 3 | 4
  eager?: number
}

const { images, columns = 3, eager = 0 } = Astro.props

const colClass = {
  2: "sm:columns-2",
  3: "sm:columns-2 lg:columns-3",
  4: "sm:columns-2 lg:columns-4",
}[columns]

const gallerySizes =
  columns === 2
    ? "(max-width: 640px) calc(100vw - 2.5rem), calc((100vw - 2rem) / 2)"
    : columns === 4
      ? "(max-width: 640px) calc(100vw - 2.5rem), (max-width: 1024px) calc((100vw - 2rem) / 2), calc((100vw - 3rem) / 4)"
      : "(max-width: 640px) calc(100vw - 2.5rem), (max-width: 1024px) calc((100vw - 2rem) / 2), calc((100vw - 3rem) / 3)"
---

<div class={`gallery-grid ${colClass} gap-4 [column-fill:_balance]`}>
  {
    images.map((img, i) => (
      <figure class="reveal img-zoom mb-4 break-inside-avoid overflow-hidden rounded-[var(--radius-card)] border border-line bg-stone">
        <button
          type="button"
          class="gallery-trigger block w-full text-left"
          data-src={img.src.src}
          data-alt={img.alt}
          data-caption={img.caption ?? img.alt}
        >
          <Image
            src={img.src}
            alt={img.alt}
            layout="constrained"
            width={750}
            quality={65}
            sizes={gallerySizes}
            loading={i < eager ? "eager" : "lazy"}
            decoding="async"
            class="w-full object-cover"
          />
        </button>
        {img.caption && (
          <figcaption class="px-3.5 py-2.5 text-xs leading-relaxed text-muted">{img.caption}</figcaption>
        )}
      </figure>
    ))
  }
</div>

<!-- Lightbox -->
<div
  id="lightbox"
  class="fixed inset-0 z-[90] hidden items-center justify-center bg-ink/92 p-4 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Image viewer"
>
  <button id="lightbox-close" class="absolute right-5 top-5 flex h-11 w-11 items-center justify-center rounded-full bg-parchment/10 text-parchment transition hover:bg-parchment/20" aria-label="Close">
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
  </button>
  <figure class="flex max-h-[88vh] max-w-5xl flex-col items-center">
    <img id="lightbox-img" src="" alt="" loading="lazy" class="max-h-[80vh] w-auto rounded-lg object-contain" />
    <figcaption id="lightbox-caption" class="mt-3 max-w-2xl text-center text-sm text-parchment/80"></figcaption>
  </figure>
</div>

<script>
  const lightbox = document.getElementById("lightbox")
  const lbImg = document.getElementById("lightbox-img") as HTMLImageElement | null
  const lbCap = document.getElementById("lightbox-caption")
  const closeBtn = document.getElementById("lightbox-close")

  function open(src: string, alt: string, caption: string) {
    if (!lightbox || !lbImg || !lbCap) return
    lbImg.src = src
    lbImg.alt = alt
    lbCap.textContent = caption
    lightbox.classList.remove("hidden")
    lightbox.classList.add("flex")
    document.body.style.overflow = "hidden"
  }
  function close() {
    if (!lightbox) return
    lightbox.classList.add("hidden")
    lightbox.classList.remove("flex")
    document.body.style.overflow = ""
  }

  document.querySelectorAll(".gallery-trigger").forEach((btn) => {
    btn.addEventListener("click", () => {
      const el = btn as HTMLElement
      open(el.dataset.src ?? "", el.dataset.alt ?? "", el.dataset.caption ?? "")
    })
  })
  closeBtn?.addEventListener("click", close)
  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) close()
  })
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") close()
  })
</script>
