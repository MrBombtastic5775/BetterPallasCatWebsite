---
import { rangeData } from "../data/manul-range.js"
import "leaflet/dist/leaflet.css"
---

<div id="range-map" class="w-full aspect-[16/9] rounded-[var(--radius-card)] border border-line overflow-hidden bg-stone" data-range={JSON.stringify(rangeData)}></div>

<style>
  #range-map {
    height: 100%;
  }
  .leaflet-container {
    font-family: var(--font-sans);
    background: var(--color-parchment);
  }
  .leaflet-popup-content-wrapper {
    border-radius: var(--radius-card);
    box-shadow: 0 10px 30px -10px rgb(0 0 0 / 0.3);
    background: var(--color-parchment);
    color: var(--color-ink);
  }
  .leaflet-popup-content {
    margin: 1rem;
    line-height: 1.5;
    font-size: 0.875rem;
  }
  .leaflet-popup-tip {
    background: var(--color-parchment);
  }
  .leaflet-control-layers {
    background: var(--color-parchment);
    border-radius: var(--radius-card);
    box-shadow: 0 4px 12px -4px rgb(0 0 0 / 0.2);
    border: 1px solid var(--color-line);
  }
  .leaflet-control-layers-expanded {
    padding: 0.5rem;
  }
  .leaflet-control-layers label {
    font-size: 0.8125rem;
    color: var(--color-ink);
  }
  .leaflet-control-zoom {
    border: none;
    box-shadow: 0 4px 12px -4px rgb(0 0 0 / 0.2);
  }
  .leaflet-control-zoom a {
    background: var(--color-parchment);
    color: var(--color-ink);
    border: 1px solid var(--color-line);
    width: 2rem;
    height: 2rem;
    line-height: 2rem;
    font-size: 1.125rem;
  }
  .leaflet-control-zoom a:hover {
    background: var(--color-stone);
  }
  .leaflet-control-attribution {
    background: rgba(246, 242, 234, 0.9);
    backdrop-filter: blur(4px);
  }
  .range-legend {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    z-index: 400;
    background: var(--color-parchment);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    padding: 0.75rem 1rem;
    box-shadow: 0 4px 12px -4px rgb(0 0 0 / 0.15);
    font-size: 0.75rem;
    line-height: 1.6;
  }
  .range-legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .range-legend-color {
    width: 1rem;
    height: 1rem;
    border-radius: 2px;
    border: 1px solid var(--color-line);
  }
  .current-color { background: rgba(179, 85, 47, 0.35); }
  .historical-color { background: rgba(111, 122, 90, 0.25); }
</style>

<script is:inline>
  (async () => {
    // Pass data via data attribute
    const mapContainer = document.getElementById('range-map')
    if (!mapContainer) return

    const rangeData = JSON.parse(mapContainer.dataset.range || '{"features":[]}')

    // Load Leaflet (bundled)
    const L = await import('leaflet')
    delete L.Icon.Default.prototype._getIconUrl
    L.Icon.Default.mergeOptions({
      iconRetinaUrl: '/images/leaflet/marker-icon-2x.png',
      iconUrl: '/images/leaflet/marker-icon.png',
      shadowUrl: '/images/leaflet/marker-shadow.png',
    })

    const map = L.map(mapContainer, {
      center: [42, 82],
      zoom: 3.5,
      minZoom: 2,
      maxZoom: 7,
      zoomControl: true,
      attributionControl: true,
      preferCanvas: true,
    })

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 7,
    }).addTo(map)

    const currentStyle = {
      fillColor: '#b4552f',
      weight: 1.5,
      opacity: 0.8,
      color: '#b4552f',
      fillOpacity: 0.25,
      dashArray: '0',
    }

    const historicalStyle = {
      fillColor: '#6f7a5a',
      weight: 1.5,
      opacity: 0.5,
      color: '#6f7a5a',
      fillOpacity: 0.12,
      dashArray: '6, 4',
    }

    function highlightFeature(e) {
      const layer = e.target
      layer.setStyle({
        weight: 2.5,
        opacity: 1,
        fillOpacity: layer.feature.properties.type === 'current' ? 0.35 : 0.18,
      })
      layer.bringToFront()
    }

    function resetHighlight(e) {
      const layer = e.target
      const style = layer.feature.properties.type === 'current' ? currentStyle : historicalStyle
      layer.setStyle(style)
    }

    function onEachFeature(feature, layer) {
      layer.on({
        mouseover: highlightFeature,
        mouseout: resetHighlight,
      })

      const props = feature.properties
      layer.bindPopup(`<strong>${props.name}</strong><br>${props.description}`)
    }

    const currentLayer = L.geoJSON(rangeData.features.filter(f => f.properties.type === 'current'), {
      style: currentStyle,
      onEachFeature,
    }).addTo(map)

    const historicalLayer = L.geoJSON(rangeData.features.filter(f => f.properties.type === 'historical'), {
      style: historicalStyle,
      onEachFeature,
    })

    const baseLayers = {
      'Light Map': map._layers[Object.keys(map._layers)[0]],
    }

    const overlays = {
      'Current Range': currentLayer,
      'Historical Range': historicalLayer,
    }

    L.control.layers(baseLayers, overlays, { collapsed: false }).addTo(map)

    const legend = L.control({ position: 'bottomleft' })
    legend.onAdd = function () {
      const div = L.DomUtil.create('div', 'range-legend')
      div.innerHTML = `
        <div class="range-legend-item">
          <span class="range-legend-color current-color"></span>
          <span>Current Range</span>
        </div>
        <div class="range-legend-item">
          <span class="range-legend-color historical-color" style="border-style: dashed;"></span>
          <span>Historical Range</span>
        </div>
      `
      return div
    }
    legend.addTo(map)

    map.fitBounds(currentLayer.getBounds().pad(0.15))
  })()
</script>